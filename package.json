{
  "name": "whatsapp-human-inbox-mvp",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' lint",
    "test": "pnpm --filter './apps/*' test"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "workspaces": [
      "apps/*",
      "packages/*"
    ]
  }
}
